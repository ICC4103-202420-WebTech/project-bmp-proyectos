
<!DOCTYPE html>
<html>
  <head>
    <title>BmpProject</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csp_meta_tag %>
    <%= csrf_meta_tags %>

    <!-- Link to your Bootstrap stylesheet -->
    <%= stylesheet_link_tag "application.bootstrap", "data-turbo-track": "reload" %>

    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body>
    <nav>
      <% if user_signed_in? %>
        <%= link_to "Log out", destroy_user_session_path, method: :delete, data: { turbo: false, confirm: "Are you sure you want to log out?" } %>
      <% else %>
        <%= link_to "Log in", new_user_session_path %>
        <%= link_to "Sign up", new_user_registration_path %>
      <% end %>
    </nav>

    <%= yield %>
  </body>
</html>

